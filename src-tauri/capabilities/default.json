{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"opener:allow-open-path",
		"opener:allow-open-url",
		"dialog:default",
		"fs:default",
		"shell:default",
		{
			"identifier": "shell:allow-execute",
			"preference": {
				"cmd": "python3",
				"args": true
			}
		},
		{
			"identifier": "shell:allow-execute",
			"preference": {
				"cmd": "python",
				"args": true
			}
		},
		{
			"identifier": "shell:allow-execute",
			"preference": {
				"cmd": "got-ocr",
				"sidecar": true
			}
		}
	]
}
