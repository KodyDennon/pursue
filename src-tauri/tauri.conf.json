{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "PURSUE Data Analyzer",
	"version": "0.6.2",
	"identifier": "com.pursue-data-analyzer",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "PURSUE Data Analyzer",
				"width": 1280,
				"height": 840,
				"resizable": true,
				"fullscreen": false,
				"transparent": true,
				"decorations": false,
				"visible": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
